# LearnFlow 服务端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=postgresql://learnflow_user:YOUR_DB_PASSWORD@localhost:5432/learnflow

# JWT配置
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE
JWT_EXPIRES_IN=7d
ENABLE_OAUTH_LOGIN=false

# 服务器配置
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
REDIS_URL=redis://localhost:6379
AGENT_WORKER_CONCURRENCY=4

# AI 服务（Wave 3.5：默认走阿里百炼兼容 OpenAI 协议；密钥仅存环境变量）
# 推荐：百炼（DashScope）— 与后台「大模型运行配置」默认 Profile 一致
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 兼容：仍可使用 OpenRouter 或自建网关（可在管理后台切换默认 Profile 为 OPENROUTER_COMPAT）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen3.6-plus
OPENROUTER_MAX_TOKENS=4000
OPENROUTER_TEMPERATURE=0.7

# 安全配置
CORS_ORIGIN=http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 日志配置
LOG_LEVEL=info
LOG_FILE=/var/log/learnflow/server.log

# 性能配置
NODE_OPTIONS=--max-old-space-size=512

# 重要提醒：
# 1. 复制此文件为 .env
# 2. 修改所有 YOUR_* 占位符为实际值
# 3. 填写 OpenAI 协议兼容服务的 API Key 与 Base URL
# 4. 不要将此文件提交到Git
